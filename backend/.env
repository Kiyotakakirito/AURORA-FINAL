# ============================================================
# AURORA — Backend Environment Configuration
# ============================================================

# Application
APP_NAME=AI Project Evaluation System
DEBUG=True
VERSION=2.0.0

# Supabase (already configured in config.py defaults, override here if needed)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key

# Database (uses in-memory SQLite dummy; real data is in Supabase)
DATABASE_URL=sqlite:///./aurora.db

# ── Ollama ────────────────────────────────────────────────────
# Local Ollama endpoint (llama3:latest is pulled and available)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3:latest

# File uploads
MAX_FILE_SIZE=104857600
UPLOAD_DIR=uploads

# Scoring weights
DEFAULT_CODE_WEIGHT=0.7
DEFAULT_REPORT_WEIGHT=0.3
MAX_SCORE=100
CODE_QUALITY_WEIGHT=0.3
FUNCTIONALITY_WEIGHT=0.4
DOCUMENTATION_WEIGHT=0.2
INNOVATION_WEIGHT=0.1
