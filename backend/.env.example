# Application Settings
APP_NAME=AI Project Evaluation System
DEBUG=True
VERSION=1.0.0

# Database Settings
DATABASE_URL=sqlite:///./evaluation_system.db

# AI API Keys (Optional - system will work without these)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Upload Settings
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads

# Evaluation Settings
DEFAULT_CODE_WEIGHT=0.7
DEFAULT_REPORT_WEIGHT=0.3
MAX_SCORE=100

# Scoring Rubric Defaults
CODE_QUALITY_WEIGHT=0.3
FUNCTIONALITY_WEIGHT=0.4
DOCUMENTATION_WEIGHT=0.2
INNOVATION_WEIGHT=0.1
